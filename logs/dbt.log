  create view "dev"."main"."customers__dbt_tmp" as (
    with customers as (
    select 
        id as customer_id,
        firstname,
        lastname
    from "dev"."main"."shop_customers"
),

orders as (
    select
        id as order_id,
        user_id as customer_id,
        order_date,
        status,
        _etl_loaded_at
    from "dev"."main"."orders"
),

stripe_payments as (
    select
        orderid as order_id,
        amount,
        payment_method,
        status,
        created,
        _batched_at
    from "dev"."main"."stripe_payment"
),

customer_orders as (
    select
        customer_id,
        min(order_date) as first_order_date,
        max(order_date) as most_recent_order_date,
        count(order_id) as number_of_orders
    from orders
    group by customer_id
),

final as (
    select
        c.customer_id,
        c.firstname,
        c.lastname,
        co.first_order_date,
        co.most_recent_order_date,
        co.number_of_orders,
        sum(sp.amount) as total_amount,
        array_agg(distinct sp.payment_method) as payment_methods
    from customers c
    left join customer_orders co 
        on c.customer_id = co.customer_id
    left join orders o 
        on c.customer_id = o.customer_id
    left join stripe_payments sp 
        on o.order_id = sp.order_id
    group by 
        c.customer_id,
        c.firstname,
        c.lastname,
        co.first_order_date,
        co.most_recent_order_date,
        co.number_of_orders
)

select * from final
  );

