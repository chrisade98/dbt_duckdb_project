    from "dev"."main"."shop_customers"
),

orders as (
    select
    id as order_id,
    user_id as customer_id,
    order_date,
    status,
    _etl_loaded_at
    from "dev"."main"."orders"
),

stripe_payments as (
    select
    orderid as payment_id,
    amount,
    payment_method,
    status,
    created,
    _batched_at
    from "dev"."main"."stripe_payment"
),

customer_orders as (
    select
    customer_id,
    order_id,
    min(order_date) as first_order_date,
    max(order_date) as most_recent_order_date,
    count(order_id) as number_of_orders,
    from orders
    group by customer_id
),

final as (
    select
    c.customer_id,
    c.firstname,
    c.lastname,
    co.first_order_date,
    co.most_recent_order_date,
    co.number_of_orders
    sp.amount,
    sp.payment_method
    from customer_orders co
    right join customers c on c.customer_id = co.customer_id
    left join stripe_payments sp on c.order_id = sp.payment_id
)
select * from final
  );

