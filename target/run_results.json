       c.customer_id,\n        c.firstname,\n        c.lastname,\n        co.first_order_date,\n        co.most_recent_order_date,\n        co.number_of_orders,\n        sum(sp.amount) as total_amount,\n        array_agg(distinct sp.payment_method) as payment_methods\n    from customers c\n    left join customer_orders co \n        on c.customer_id = co.customer_id\n    left join orders o \n        on c.customer_id = o.customer_id\n    left join stripe_payments sp \n        on o.order_id = sp.order_id\n    group by \n        c.customer_id,\n        c.firstname,\n        c.lastname,\n        co.first_order_date,\n        co.most_recent_order_date,\n        co.number_of_orders\n)\n\nselect * from final", "relation_name": "\"dev\".\"main\".\"customers\"", "batch_results": null}], "elapsed_time": 0.8595542907714844, "args": {"require_generic_test_arguments_property": true, "use_fast_test_edges": false, "source_freshness_run_project_hooks": true, "defer": false, "project_dir": "C:\\Users\\chris\\dbt_workspace\\dbt_duckdb_project", "state_modified_compare_more_unrendered_values": false, "macro_debugging": false, "print": true, "require_ref_searches_node_package_before_root": false, "indirect_selection": "eager", "printer_width": 80, "require_unique_project_resource_names": false, "upload_to_artifacts_ingest_api": false, "select": [], "partial_parse_file_diff": true, "quiet": false, "cache_selected_only": false, "require_explicit_package_overrides_for_builtin_materializations": true, "which": "run", "send_anonymous_usage_stats": true, "profiles_dir": "C:\\Users\\chris\\.dbt", "require_yaml_configuration_for_mf_time_spines": false, "exclude": [], "vars": {}, "validate_macro_args": false, "skip_nodes_if_on_run_start_fails": false, "partial_parse": true, "strict_mode": false, "use_colors_file": true, "warn_error_options": {"error": [], "warn": [], "silence": []}, "show_all_deprecations": false, "require_all_warnings_handled_by_warn_error": false, "log_format_file": "debug", "